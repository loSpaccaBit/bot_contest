# ─────────────────────────────────────────────────────────────────────────────
# Domusbet Referral — Environment Variables Example
#
# Copy this file to .env and fill in your actual values before starting any
# service.  Values marked with ⚠️  CHANGE THIS are insecure defaults that MUST
# be replaced in any non-development environment.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Runtime ─────────────────────────────────────────────────────────────────

# Application environment.
# Valid values: development | production | test
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────

# Full PostgreSQL connection URL used by Prisma.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:password@localhost:5432/domusbet_referral

# ─── Redis ────────────────────────────────────────────────────────────────────

# Full Redis connection URL used by BullMQ and session caching.
REDIS_URL=redis://localhost:6379

# Redis host (used when connecting without a full URL).
REDIS_HOST=localhost

# Redis port.
REDIS_PORT=6379

# ─── API Service ─────────────────────────────────────────────────────────────

# Port the NestJS API listens on.
API_PORT=3001

# Host the NestJS API binds to. Use 0.0.0.0 inside Docker.
API_HOST=0.0.0.0

# Allowed CORS origin for browser-based clients (admin dashboard).
CORS_ORIGIN=http://localhost:3000

# ─── JWT Authentication ───────────────────────────────────────────────────────

# Secret used to sign access tokens.  Minimum 32 characters.
# ⚠️  CHANGE THIS — generate with: openssl rand -hex 32
JWT_SECRET=change_me_use_openssl_rand_hex_32_at_least

# Access token TTL.  Accepts zeit/ms notation: 15m, 1h, 7d …
JWT_EXPIRES_IN=15m

# Secret used to sign refresh tokens.  Must differ from JWT_SECRET.
# ⚠️  CHANGE THIS — generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret_32chars

# Refresh token TTL.
JWT_REFRESH_EXPIRES_IN=7d

# ─── Internal API Secret ─────────────────────────────────────────────────────

# Shared secret used to authenticate requests from the bot and worker to the
# internal /api/internal/* routes.  Minimum 16 characters.
# ⚠️  CHANGE THIS — generate with: openssl rand -hex 20
API_INTERNAL_SECRET=change_me_internal_secret_min16

# ─── Telegram Bot ────────────────────────────────────────────────────────────

# Token provided by @BotFather when you create the bot.
# ⚠️  REQUIRED — obtain from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-example

# Optional webhook URL.  If set the bot uses webhook mode; otherwise it polls.
# Requires a publicly accessible HTTPS URL.
# BOT_WEBHOOK_URL=https://yourdomain.com/bot-webhook

# URL the bot service uses to reach the API service.
# Inside Docker: http://api:3001.  On host dev: http://localhost:3001.
BOT_API_URL=http://localhost:3001

# Internal secret reused by the bot (alias for API_INTERNAL_SECRET).
BOT_API_INTERNAL_SECRET=change_me_internal_secret_min16

# ─── Worker Service ───────────────────────────────────────────────────────────

# URL the worker service uses to reach the API service.
# Inside Docker: http://api:3001.  On host dev: http://localhost:3001.
WORKER_API_URL=http://localhost:3001

# Internal secret reused by the worker (alias for API_INTERNAL_SECRET).
WORKER_API_INTERNAL_SECRET=change_me_internal_secret_min16

# BullMQ worker concurrency (number of concurrent jobs per queue).
WORKER_CONCURRENCY=5

# Maximum number of times a stalled job can be retried before being moved to
# the failed state.
WORKER_MAX_STALLED_COUNT=3

# ─── Admin Dashboard (Next.js) ────────────────────────────────────────────────

# Public API URL used by the browser.  Must be reachable from end-user devices.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Secret used by NextAuth.js to sign session tokens.
# ⚠️  CHANGE THIS — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=change_me_nextauth_secret_min32_chars

# Canonical URL of the admin dashboard.  NextAuth redirects back here.
NEXTAUTH_URL=http://localhost:3000

# ─── Throttling (optional overrides) ─────────────────────────────────────────

# Maximum requests per second per IP (short window).
THROTTLE_SHORT_LIMIT=10

# Maximum requests per 10 seconds per IP (medium window).
THROTTLE_MEDIUM_LIMIT=50

# Maximum requests per minute per IP (long window).
THROTTLE_LONG_LIMIT=100

# ─── Logging ─────────────────────────────────────────────────────────────────

# Log level for all services.
# Valid values: debug | info | warn | error
LOG_LEVEL=debug

# Human-readable application name included in log entries.
APP_NAME=Domusbet Referral
