# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example — Template variabili per la VPS
#
# Copia questo file su /opt/domusbet/.env.production e compila tutti i valori.
# NON committare il file compilato su git.
#
#   chmod 600 /opt/domusbet/.env.production
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=domusbet_referral
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_CON_PASSWORD_SICURA

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=https://panel.fcast7.it

# ⚠️  CAMBIA — genera con: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=15m

# ⚠️  CAMBIA — genera con: openssl rand -hex 32 (diverso da JWT_SECRET)
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ⚠️  CAMBIA — genera con: openssl rand -hex 20
API_INTERNAL_SECRET=

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
BOT_USERNAME=contest_tipster_bot
TELEGRAM_CHANNEL_ID=-1001683966935

# URL base per il webhook (senza /bot-webhook — lo aggiunge il bot)
BOT_WEBHOOK_URL=https://api.fcast7.it

# ─── Admin Web ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://panel.fcast7.it
NEXT_PUBLIC_API_URL=https://api.fcast7.it

# ⚠️  CAMBIA — genera con: openssl rand -hex 32
NEXTAUTH_SECRET=

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_API_URL=http://api:3001
WORKER_API_INTERNAL_SECRET=  # stesso valore di API_INTERNAL_SECRET
BOT_API_URL=http://api:3001
BOT_API_INTERNAL_SECRET=     # stesso valore di API_INTERNAL_SECRET
WORKER_CONCURRENCY=5
WORKER_MAX_STALLED_COUNT=3

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
APP_NAME=Domusbet Referral
NODE_ENV=production
